#!/usr/bin/env bash
# pin — drop an HTML file (or a folder containing index.html) onto GitHub Pages,
# tag it, and refresh the bulletin-board index.
#
# Usage:
#   pin <file.html> [slug] [--title "Nice Title"] [--tag "Maui Trip"] [--tag Hiking]
#   pin <file.html> [slug] [--tags "Maui Trip,Hiking"]
#   pin <folder>   [slug] ...     # folder must contain index.html (for pages with assets)
#
# Notes:
#   - slug defaults to a cleaned version of the filename.
#   - title defaults to the page's <title>, else the slug.
#   - On repin, omit --tag/--tags to keep the existing tags.
#
set -euo pipefail

USER="asp-lhp"
REPO_DIR="$HOME/microsites"

SRC=""; SLUG=""; TITLE=""; TAGS=""
while [[ $# -gt 0 ]]; do
  case "$1" in
    --title) TITLE="${2:-}"; shift 2;;
    --tags)  TAGS="${2:-}"; shift 2;;
    --tag)   TAGS="${TAGS:+$TAGS,}${2:-}"; shift 2;;
    -h|--help) sed -n '2,18p' "$0"; exit 0;;
    -*) echo "Unknown option: $1" >&2; exit 1;;
    *)  if [[ -z "$SRC" ]]; then SRC="$1"; elif [[ -z "$SLUG" ]]; then SLUG="$1"; fi; shift;;
  esac
done

if [[ -z "$SRC" ]]; then
  echo "Usage: pin <file.html | folder> [slug] [--title \"...\"] [--tag \"...\"]" >&2
  exit 1
fi
if [[ ! -e "$SRC" ]]; then
  echo "Error: '$SRC' not found." >&2
  exit 1
fi

# Derive a clean URL slug from the filename if one wasn't given.
if [[ -z "$SLUG" ]]; then
  base="$(basename "$SRC")"; base="${base%.*}"
  SLUG="$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]' | tr ' _' '--' | tr -cd 'a-z0-9-')"
fi
if [[ -z "$SLUG" ]]; then
  echo "Error: could not derive a slug; pass one explicitly: pin <file> <slug>" >&2
  exit 1
fi

DEST="$REPO_DIR/$SLUG"

git -C "$REPO_DIR" pull --quiet --no-rebase origin main 2>/dev/null || true
rm -rf "$DEST"; mkdir -p "$DEST"

if [[ -d "$SRC" ]]; then
  cp -R "$SRC"/. "$DEST"/
  if [[ ! -f "$DEST/index.html" ]]; then
    echo "Error: folder '$SRC' has no index.html." >&2; rm -rf "$DEST"; exit 1
  fi
else
  cp "$SRC" "$DEST/index.html"
fi

# Default the title to the page's <title>, then to the slug.
if [[ -z "$TITLE" ]]; then
  TITLE="$(grep -o -i '<title>[^<]*</title>' "$DEST/index.html" | head -1 | sed -E 's/<[^>]*>//g' | sed -E 's/^[[:space:]]+|[[:space:]]+$//g')"
  [[ -z "$TITLE" ]] && TITLE="$SLUG"
fi

# Update metadata + regenerate the bulletin board.
python3 "$REPO_DIR/_upsert.py" "$SLUG" "$TITLE" "$TAGS"
python3 "$REPO_DIR/build-index.py" >/dev/null

git -C "$REPO_DIR" add -A
if git -C "$REPO_DIR" diff --cached --quiet; then
  echo "No changes — '$SLUG' is already up to date."
else
  git -C "$REPO_DIR" commit --quiet -m "Pin $SLUG"
  git -C "$REPO_DIR" push --quiet origin main
fi

echo ""
echo "✅ Pinned: https://$USER.github.io/microsites/$SLUG/"
echo "   Title: $TITLE"
echo "   Tags:  ${TAGS:-(unchanged)}"
echo "   Board: https://$USER.github.io/microsites/"
